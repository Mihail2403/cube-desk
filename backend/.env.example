DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cube_desk
SQLALCHEMY_ECHO=False

SALT=test-salt

# Comma-separated list of origins. If empty, CORS middleware is not enabled.
CORS_ALLOW_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# MinIO (S3-compatible) for message attachments (local dev: docker compose from repo root)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123456

# Backend S3 client settings (use http://minio:9000 when backend runs inside the same compose network)
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123456
S3_BUCKET=cube-desk-attachments
S3_USE_SSL=False

# Presigned GET URL lifetime in seconds
S3_PRESIGNED_GET_TTL_SECONDS=600

# Attachment limits
ATTACHMENTS_MAX_FILES=10
ATTACHMENTS_MAX_FILE_SIZE_BYTES=10485760